		},
		{"id":"edf86b2ecbb58263","type":"text","text":"`GetJournalIndex ABcm_HR_Mine 100`","x":8260,"y":101,"width":200,"height":84,"color":"4"},
		{"id":"e1e70d53b4bb8cba","type":"text","text":"## \" [[Uveran]]\nThis is an important step for the Uveran family. And in no small thanks to your interventions.","x":8500,"y":59,"width":240,"height":169,"color":"3"},
		{"id":"ab9ee3416f93bfa4","type":"text","text":"AddTopic \"Uveran family\"","x":8500,"y":260,"width":240,"height":60,"color":"6"},
